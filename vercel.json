{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "outputDirectory": "public",
  "functions": {
    "api/index.js": {
      "maxDuration": 15
    }
  },
  "rewrites": [
    { "source": "/app", "destination": "/app.html" },
    { "source": "/api/(.*)", "destination": "/api" },
    { "source": "/badge/(.*)", "destination": "/api" }
  ]
}
