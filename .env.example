# Copy this file to `.env` and fill in real values.
# `.env` is gitignored — keep your secrets there.

# Bitget Agent Hub credentials (only needed for trading agents — monitoring is read-only)
BITGET_API_KEY=
BITGET_SECRET_KEY=
BITGET_PASSPHRASE=

# Bitget GetAgent Playbook control-plane key (for examples/playbook-watched.ts)
BITGET_PLAYBOOK_KEY=
PLAYBOOK_VERSION_ID=

# Anthropic API key for AI incident diagnosis (Layer 3).
# Without these, WATCHDOG falls back to a templated diagnosis — the demo never breaks.
WATCHDOG_AI_API_KEY=
WATCHDOG_AI_MODEL=claude-sonnet-4-6

# Dashboard server
WATCHDOG_PORT=3000
