# Copy this file to `.env` and fill in real values.
# `.env` is gitignored — keep your secrets there.

# Bitget Agent Hub credentials (only needed for trading agents — monitoring is read-only)
BITGET_API_KEY=
BITGET_SECRET_KEY=
BITGET_PASSPHRASE=

# Bitget DEMO (paper) trading keys — for examples/paper-trade.ts to place REAL demo orders.
# Create at Bitget → Demo Trading → API. Live keys do NOT work for paper trading.
# Without these, paper-trade.ts runs in signal-only mode (still uses real live price).
BITGET_DEMO_API_KEY=
BITGET_DEMO_SECRET_KEY=
BITGET_DEMO_PASSPHRASE=

# Bitget GetAgent Playbook control-plane key (for examples/playbook-watched.ts)
BITGET_PLAYBOOK_KEY=
PLAYBOOK_VERSION_ID=

# AI key for Layer 3 (incident diagnosis) and Layer 6 (behavioral supervisor).
# WATCHDOG is model-agnostic: use Claude OR any OpenAI-compatible model (Qwen, etc.).
# Without a key, both layers fall back to heuristic/templated output, so the demo never breaks.
#
# Option A — Claude (Anthropic):
#   WATCHDOG_AI_API_KEY=sk-ant-...
#   WATCHDOG_AI_MODEL=claude-sonnet-4-6
#
# Option B — Alibaba Qwen (DashScope, OpenAI-compatible) — aligns with the Bitget AI stack:
#   WATCHDOG_AI_API_KEY=sk-...                 # your DashScope key
#   WATCHDOG_AI_MODEL=qwen-plus                # or qwen-max, qwen-turbo
#   # base URL auto-defaults to DashScope international; override for mainland:
#   # WATCHDOG_AI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
#
# Provider is auto-detected from the model name; force it with WATCHDOG_AI_PROVIDER=anthropic|openai
WATCHDOG_AI_API_KEY=
WATCHDOG_AI_MODEL=claude-sonnet-4-6
# WATCHDOG_AI_BASE_URL=
# WATCHDOG_AI_PROVIDER=

# Dashboard server
WATCHDOG_PORT=3000
